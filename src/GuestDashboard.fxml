<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="GuestDashboardController"
            prefHeight="650" prefWidth="1100"
            styleClass="root-pane">

    <BorderPane AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <top>
            <HBox alignment="CENTER_LEFT" spacing="15" styleClass="header-bar">
                <Label text="Guest Dashboard" styleClass="header-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="welcomeLabel" text="Welcome, Guest" style="-fx-text-fill: #ecf0f1; -fx-font-size: 14px;"/>
                <Button text="Logout" onAction="#handleLogout" styleClass="btn-danger"
                        style="-fx-font-size: 12px; -fx-padding: 6 16;"/>
            </HBox>
        </top>

        <center>
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                <VBox spacing="25" alignment="TOP_CENTER" style="-fx-padding: 30;">
                    <HBox spacing="30" alignment="CENTER">
                        <VBox spacing="12" styleClass="profile-card" prefWidth="350">
                            <Label text="Profile Information" style="-fx-text-fill: #3498db; -fx-font-size: 18px; -fx-font-weight: bold;"/>

                            <HBox spacing="10">
                                <Label text="Username:" styleClass="field-label-light" prefWidth="120"/>
                                <Label fx:id="profileUsername" text="-" styleClass="info-value-light"/>
                            </HBox>
                            <HBox spacing="10">
                                <Label text="Gender:" styleClass="field-label-light" prefWidth="120"/>
                                <Label fx:id="profileGender" text="-" styleClass="info-value-light"/>
                            </HBox>
                            <HBox spacing="10">
                                <Label text="Age:" styleClass="field-label-light" prefWidth="120"/>
                                <Label fx:id="profileAge" text="-" styleClass="info-value-light"/>
                            </HBox>
                            <HBox spacing="10">
                                <Label text="Address:" styleClass="field-label-light" prefWidth="120"/>
                                <Label fx:id="profileAddress" text="-" styleClass="info-value-light" wrapText="true"/>
                            </HBox>
                            <HBox spacing="10">
                                <Label text="Preferences:" styleClass="field-label-light" prefWidth="120"/>
                                <Label fx:id="profilePrefs" text="-" styleClass="info-value-light" wrapText="true"/>
                            </HBox>
                        </VBox>
                        <VBox spacing="10" alignment="CENTER" styleClass="profile-card" prefWidth="220">
                            <Label text="Account Balance" style="-fx-text-fill: #ecf0f1; -fx-font-size: 14px;"/>
                            <Label fx:id="balanceLabel" text="0.00$" styleClass="balance-label"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="20" alignment="CENTER">
                        <Button text="🔍 Browse Rooms" onAction="#handleBrowseRooms" styleClass="btn-nav"/>
                        <Button text="📋 My Reservations" onAction="#handleMyReservations" styleClass="btn-nav"/>
                        <Button text="💳 Checkout and Pay" onAction="#handleCheckout" styleClass="btn-nav"/>
                    </HBox>
                    <VBox spacing="10">
                        <Label text="Active Reservations" style="-fx-text-fill: #ecf0f1; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                        <TableView fx:id="reservationsTable" prefHeight="220">
                            <columns>
                                <TableColumn fx:id="columnRoomNum" text="Room #" prefWidth="80"/>
                                <TableColumn fx:id="columnRoomType" text="Room Type" prefWidth="120"/>
                                <TableColumn fx:id="columnCheckIn" text="Check-In" prefWidth="130"/>
                                <TableColumn fx:id="columnCheckOut" text="Check-Out" prefWidth="130"/>
                                <TableColumn fx:id="columnStatus" text="Status" prefWidth="120"/>
                                <TableColumn fx:id="columnPaid" text="Paid" prefWidth="70"/>
                            </columns>
                            <placeholder>
                                <Label text="No active reservations" style="-fx-text-fill: rgba(255,255,255,0.5);"/>
                            </placeholder>
                        </TableView>
                    </VBox>
                </VBox>
            </ScrollPane>
        </center>

        <!-- LIVE CHAT SIDEBAR -->
        <right>
            <VBox spacing="10" prefWidth="280" styleClass="profile-card" style="-fx-padding: 15; -fx-border-width: 0 0 0 1; -fx-border-color: #2c3e50;">
                <Label text="💬 Live Front Desk Chat" style="-fx-text-fill: #3498db; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                <TextArea fx:id="chatTextArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS" style="-fx-font-family: 'Segoe UI'; -fx-font-size: 13px; -fx-control-inner-background: #ecf0f1;"/>
                <HBox spacing="8">
                    <TextField fx:id="chatInputField" promptText="Type a message..." onAction="#handleSendMessage" HBox.hgrow="ALWAYS" style="-fx-background-radius: 4;"/>
                    <Button text="Send" onAction="#handleSendMessage" styleClass="btn-primary" style="-fx-padding: 5 12;"/>
                </HBox>
            </VBox>
        </right>

    </BorderPane>
</AnchorPane>